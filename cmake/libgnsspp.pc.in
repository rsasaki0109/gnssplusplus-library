prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: libgnsspp
Description: GNSS processing library and CLI toolchain
Version: @PROJECT_VERSION@
Requires: eigen3
Libs: -L${libdir} -lgnss_lib -lgnss_lib_noopt
Cflags: -I${includedir}
